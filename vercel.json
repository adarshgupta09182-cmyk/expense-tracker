{
  "version": 2,
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/budget(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/expenses(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/recurring-expenses(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/export(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/$1"
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret",
    "RESEND_API_KEY": "@resend_api_key",
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}
